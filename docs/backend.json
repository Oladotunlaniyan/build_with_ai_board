{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "nickname": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["id", "email", "nickname", "role"]
    },
    "Project": {
      "title": "Project",
      "type": "object",
      "description": "Represents a project submitted by a user.",
      "properties": {
        "title": { "type": "string" },
        "shortDescription": { "type": "string" },
        "fullDescription": { "type": "string" },
        "screenshotUrl": { "type": "string", "format": "uri" },
        "screenshotHint": { "type": "string" },
        "liveUrl": { "type": "string", "format": "uri" },
        "githubUrl": { "type": "string", "format": "uri" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "userNickname": { "type": "string" },
        "techStack": { "type": "array", "items": { "type": "string" } },
        "batch": { "type": "string" }
      },
      "required": ["title", "shortDescription", "fullDescription", "screenshotUrl", "liveUrl", "githubUrl", "status", "userId", "userNickname", "techStack", "batch"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "userProfile",
          "schema": { "$ref": "#/entities/UserProfile" },
          "description": "Stores user profiles."
        }
      },
      {
        "path": "/projects/{projectId}",
        "definition": {
          "entityName": "project",
          "schema": { "$ref": "#/entities/Project" },
          "description": "Stores all projects."
        }
      },
      {
        "path": "/admins/{userId}",
        "definition": {
          "entityName": "adminUser",
          "schema": { "$ref": "#/entities/UserProfile" },
          "description": "Collection to check for admin role using exists()."
        }
      }
    ]
  }
}
